{
  "name": "how-to-ask-questions-the-smart-way",
  "version": "0.0.0",
  "private": true,
  "description": "A static Fumadocs edition of How To Ask Questions The Smart Way.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "serve out",
    "content:check": "node scripts/content-check.mjs",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "deploy": "gh-pages -d out"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.5",
    "gh-pages": "^6.3.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
